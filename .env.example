# =============================================================================
# BMI Digital Platform — Environment template
# Copy to `.env` (or `.env.local`) and fill in real values.
# `.env*` is git-ignored; `.env.example` is committed.
# Validated at boot by `lib/config/env.ts` (Zod).
# =============================================================================

# -----------------------------------------------------------------------------
# Phase 1 — Database (Neon PostgreSQL) — REQUIRED
# -----------------------------------------------------------------------------
# Use the **pooled** connection string for the application at runtime
# (Prisma uses this to keep the connection count low on serverless).
# Example: postgresql://USER:PASSWORD@ep-XXXXX-pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# Use the **direct** (un-pooled) connection string for Prisma migrations only.
# Example: postgresql://USER:PASSWORD@ep-XXXXX.REGION.aws.neon.tech/DB?sslmode=require
DIRECT_DATABASE_URL=

# -----------------------------------------------------------------------------
# Phase 1 — Seed (optional; used only by `npm run db:seed`)
# -----------------------------------------------------------------------------
# Override the placeholder admin user created by the seed. Both default if unset
# (admin@bintangmuliainvestama.co.id / "BMI Admin"). The admin's password is a
# non-functional placeholder until Phase 3 wires Auth.js.
SEED_ADMIN_EMAIL=
SEED_ADMIN_NAME=

# -----------------------------------------------------------------------------
# Phase 3 — Auth.js v5 + RBAC + MFA — REQUIRED
# -----------------------------------------------------------------------------
# JWT signing key (Auth.js v5). At least 32 random chars.
#   Generate: openssl rand -base64 32
#   Or:       node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Rotating this invalidates all live admin sessions.
AUTH_SECRET=

# Deployment base URL (origin) — Auth.js uses this for callbacks + CSRF
# allow-list. Local dev: http://localhost:3000
AUTH_URL=http://localhost:3000

# AES-256-GCM key encrypting User.mfaSecret at rest. Exactly 64 hex chars.
#   Generate: openssl rand -hex 32
#   Or:       node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this requires re-issuing MFA secrets (procedure in DEPLOYMENT.md).
MFA_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Phase 3 — Rate limiting (OPTIONAL — fails OPEN if absent, logged to AuditLog)
# -----------------------------------------------------------------------------
# Upstash Redis credentials for login + form rate limits. When unset, code
# allows requests through and writes a RATE_LIMIT_UNAVAILABLE audit entry per
# the approved Phase-3 decision. Production should always set both.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Phase 4 — Cloudinary signed uploads (OPTIONAL for local dev; REQUIRED for
# production media uploads). When unset, `MediaService.getSignedUploadPayload`
# throws "Cloudinary not configured".
# -----------------------------------------------------------------------------
# Server-side only — the browser receives cloud_name + api_key via the
# /api/v1/admin/media/sign JSON response at upload time (not at build time),
# so no NEXT_PUBLIC_ prefix is needed. api_secret signs the upload params.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# Future phases (NOT required for current scope; add as each phase lands):
#   Phase 3 — Auth.js:        AUTH_SECRET, AUTH_URL
#   Phase 4 — Cloudinary:     CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET
#   Phase 7/8 — Abuse:        UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN,
#                             TURNSTILE_SECRET_KEY, NEXT_PUBLIC_TURNSTILE_SITE_KEY
#   Phase 10 — Observability: SENTRY_DSN
# Adding env vars early would create unused config; each phase appends what it needs.
# -----------------------------------------------------------------------------
